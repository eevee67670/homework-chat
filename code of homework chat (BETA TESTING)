    async function handleLogin() {
      const username = document.getElementById('usernameInput').value.trim();
      const password = document.getElementById('passwordInput').value.trim();
      const signInBtn = document.getElementById('btnSignIn');

      if (!username || !password) {
        showLoginMessage('Please enter username and password', 'error');
        return;
      }

      // Check school hours and show field if needed
      const isSchoolHours = checkSchoolHours();
      if (isSchoolHours) {
        const schoolPasswordInput = document.getElementById('schoolPasswordInput');
        const schoolField = document.getElementById('schoolPasswordField');
        
        // Make sure field is visible
        if (schoolField) {
          schoolField.style.display = 'block';
        }
        
        const enteredSchoolPassword = (schoolPasswordInput ? schoolPasswordInput.value.trim() : '');
        
        if (!enteredSchoolPassword || enteredSchoolPassword !== schoolPassword) {
          showLoginMessage('School password required during school hours (6am-3pm)! Enter it above.', 'error');
          return;
        }
      }

      // Disable button and show loading state
      signInBtn.disabled = true;
      signInBtn.textContent = 'Checking...';
      showLoginMessage('Searching for user...', 'success');

      try {
        // Force wait for complete initialization
        if (!isInitialized) {
          showLoginMessage('Initializing app...', 'success');
          let waitTime = 0;
          while (!isInitialized && waitTime < 30000) {
            await new Promise(resolve => setTimeout(resolve, 1000));
            waitTime += 1000;
          }
          
          if (!isInitialized) {
            throw new Error('App failed to initialize');
          }
        }

        // Multiple search attempts with increasing waits
        const searchAttempts = [
          { wait: 2000, label: 'First check' },
          { wait: 3000, label: 'Second check' },
          { wait: 5000, label: 'Third check' },
          { wait: 4000, label: 'Fourth check' },
          { wait: 6000, label: 'Fifth check' }
        ];

        for (const attempt of searchAttempts) {
          await new Promise(resolve => setTimeout(resolve, attempt.wait));
          
          showLoginMessage(`Searching (${attempt.label})...`, 'success');
          
          // Force refresh of allUsers data by re-checking backend
          const user = allUsers.find(u => 
            u && u.username && u.password && 
            u.type === 'user' &&
            u.username.toLowerCase() === username.toLowerCase() && 
            u.password === password
          );
          
          if (user) {
            showLoginMessage('Logging in...', 'success');
            await handleLoginWithUser(user, signInBtn);
            return;
          }
        }

        showLoginMessage('❌ Wrong username or password', 'error');
        signInBtn.disabled = false;
        signInBtn.textContent = 'Sign In';
      } catch (error) {
        showLoginMessage('Login error: ' + (error.message || 'Unknown error'), 'error');
        signInBtn.disabled = false;
        signInBtn.textContent = 'Sign In';
      }
    }

    async function handleLoginWithUser(user, signInBtn) {
      try {
        // Check if banned
        if (user.bannedUntil && user.bannedUntil !== '') {
          const bannedUntil = new Date(user.bannedUntil);
          if (bannedUntil > new Date()) {
            const timeLeft = Math.ceil((bannedUntil - new Date()) / 60000);
            showLoginMessage(`⛔ You are banned for ${timeLeft} more minutes!`, 'error');
            signInBtn.disabled = false;
            signInBtn.textContent = 'Sign In';
            return;
          } else {
            user.bannedUntil = '';
