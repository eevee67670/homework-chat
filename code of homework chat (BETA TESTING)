      const sendBtn = document.createElement('button');
      sendBtn.className = 'btn';
      sendBtn.type = 'button';
      sendBtn.textContent = '✉️ Send';
      sendBtn.onclick = async () => {
        const recipientId = recipientSelect.value;
        const message = messageInput.value.trim();
        
        if (!recipientId) {
          showNotification('Select a recipient!', true);
          return;
        }
        
        if (!message) {
          showNotification('Enter a message!', true);
          return;
        }
        
        const result = await window.dataSdk.create({
          id: Date.now().toString(),
          type: 'mail',
          senderId: currentUser.id,
          senderName: currentUser.username,
          senderPic: currentUser.profilePicture || '📚',
          receiverId: recipientId,
          message: message,
          timestamp: new Date().toISOString()
        });
        
        if (result.isOk) {
          showNotification('Mail sent! ✉️');
          modal.remove();
          openMail();
        } else {
          showNotification('Failed to send mail!', true);
        }
      };
      modalContent.appendChild(sendBtn);
      
      const cancelBtn = document.createElement('button');
      cancelBtn.className = 'btn btn-secondary';
      cancelBtn.type = 'button';
      cancelBtn.textContent = 'Cancel';
      cancelBtn.onclick = () => modal.remove();
      modalContent.appendChild(cancelBtn);
      
      modal.appendChild(modalContent);
      document.body.appendChild(modal);
    }

    async function deleteMailMessage(mailId) {
      const mail = mailMessages.find(m => m.id === mailId);
      if (mail) {
        const result = await window.dataSdk.delete(mail);
        if (result.isOk) {
          showNotification('Mail deleted');
          openMail();
        }
      }
    }

