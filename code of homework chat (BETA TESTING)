    async function toggleFriend(userId) {
      const friendIds = currentUser.friends ? currentUser.friends.split(',').filter(f => f) : [];
      const index = friendIds.indexOf(userId);
      
      if (index > -1) {
        friendIds.splice(index, 1);
        showNotification('Friend removed');
      } else {
        friendIds.push(userId);
        showNotification('Friend added!');
      }
      
      currentUser.friends = friendIds.join(',');
      await window.dataSdk.update(currentUser);
    }

    async function toggleBlock(userId) {
      const blockedIds = currentUser.blockedUsers ? currentUser.blockedUsers.split(',').filter(b => b) : [];
      const index = blockedIds.indexOf(userId);
      
      if (index > -1) {
        blockedIds.splice(index, 1);
        showNotification('User unblocked');
      } else {
        blockedIds.push(userId);
        
        const friendIds = currentUser.friends ? currentUser.friends.split(',').filter(f => f) : [];
        const friendIndex = friendIds.indexOf(userId);
        if (friendIndex > -1) {
          friendIds.splice(friendIndex, 1);
          currentUser.friends = friendIds.join(',');
        }
        
        showNotification('User blocked');
      }
      
      currentUser.blockedUsers = blockedIds.join(',');
      await window.dataSdk.update(currentUser);
    }

