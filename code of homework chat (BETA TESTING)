    async function executeMergePets(idx1, idx2) {
      const pets = currentUser.ownedPets.split(',');
      const rarities = currentUser.petRarities.split(',');
      const levels = currentUser.petLevels.split(',');
      const names = currentUser.petNames.split(',');
      const hps = currentUser.petCurrentHP.split(',');

      const hp1 = parseInt(hps[idx1]);
      const hp2 = parseInt(hps[idx2]);

      // Keep the first pet, merge HP for increased defense
      const mergedHP = hp1 + hp2; // Combined HP for better defense

      hps[idx1] = mergedHP.toString();

      // Remove the second pet (use higher index first to avoid index shifting)
      const removeIdx = idx1 > idx2 ? idx1 : idx2;
      const keepIdx = idx1 > idx2 ? idx2 : idx1;

      pets.splice(removeIdx, 1);
      rarities.splice(removeIdx, 1);
      levels.splice(removeIdx, 1);
      names.splice(removeIdx, 1);
      hps.splice(removeIdx, 1);

      currentUser.ownedPets = pets.join(',');
      currentUser.petRarities = rarities.join(',');
      currentUser.petLevels = levels.join(',');
      currentUser.petNames = names.join(',');
      currentUser.petCurrentHP = hps.join(',');

      await window.dataSdk.update(currentUser);
      updateUI();
      showNotification(`✨ Successfully merged! ${names[keepIdx]} now has ${mergedHP} HP and deals more damage in battles! 💪⚔️`);
      openPets();
    }

