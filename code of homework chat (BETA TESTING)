    async function evolvePet(petIndex) {
      const pets = currentUser.ownedPets.split(',');
      const rarities = currentUser.petRarities.split(',');
      const levels = currentUser.petLevels.split(',');
      const names = currentUser.petNames.split(',');
      const hps = currentUser.petCurrentHP.split(',');
      
      const petEmoji = pets[petIndex];
      const petType = petTypes[petEmoji];
      const currentLevel = parseInt(levels[petIndex]);
      const requiredLevel = petEvolutionLevels[petType] || 20;
      
      if (currentLevel < requiredLevel) {
        showNotification(`Pet must be level ${requiredLevel}+ to evolve!`, true);
        return;
      }
      
      const evolutionInfo = getEvolutionInfo(petType);
      if (!evolutionInfo) {
        showNotification('This pet cannot evolve!', true);
        return;
      }
      
      const newEmoji = Object.keys(petTypes).find(emoji => petTypes[emoji] === evolutionInfo.newType);
      
      pets[petIndex] = newEmoji;
      rarities[petIndex] = evolutionInfo.newRarity;
      names[petIndex] = evolutionInfo.newName;
      hps[petIndex] = evolutionInfo.newHP.toString();
      
      currentUser.ownedPets = pets.join(',');
      currentUser.petRarities = rarities.join(',');
      currentUser.petNames = names.join(',');
      currentUser.petCurrentHP = hps.join(',');
      
      await window.dataSdk.update(currentUser);
      updateUI();
      showNotification(`${names[petIndex - 1]} evolved into ${evolutionInfo.newName}! ✨`);
      openPets();
    }

    async function sellPet(petIndex, sellPrice) {
      const pets = currentUser.ownedPets.split(',');
      const rarities = currentUser.petRarities.split(',');
      const levels = currentUser.petLevels.split(',');
      const names = currentUser.petNames.split(',');
      const hps = currentUser.petCurrentHP.split(',');
      
      const petName = names[petIndex];
      
      pets.splice(petIndex, 1);
      rarities.splice(petIndex, 1);
      levels.splice(petIndex, 1);
      names.splice(petIndex, 1);
      hps.splice(petIndex, 1);
      
      currentUser.ownedPets = pets.join(',');
      currentUser.petRarities = rarities.join(',');
      currentUser.petLevels = levels.join(',');
      currentUser.petNames = names.join(',');
      currentUser.petCurrentHP = hps.join(',');
      
      if (currentUser.role !== 'owner') {
        currentUser.coins = (currentUser.coins || 0) + sellPrice;
      }
      
      await window.dataSdk.update(currentUser);
      updateUI();
      showNotification(`Sold ${petName} for ${sellPrice} coins! 💰`);
      openPets();
    }

    // Wait for SDK to be available, then initialize
    async function setupApp() {
      // Wait for data SDK to exist
      let attempts = 0;
      while (!window.dataSdk && attempts < 100) {
        await new Promise(resolve => setTimeout(resolve, 100));
        attempts++;
      }
      
      if (!window.dataSdk) {
        showLoginMessage('App failed to initialize. Please refresh.', 'error');
        return;
      }
      
      // SDK is ready, now initialize
      await initApp();
      
      if (checkSchoolHours()) {
        const schoolField = document.getElementById('schoolPasswordField');
        if (schoolField) schoolField.style.display = 'block';
      }
    }

    // Start SDK setup immediately
    setupApp().catch(err => {
      showLoginMessage('Error: ' + err.message, 'error');
    });
    
    // Setup button handlers immediately with multiple retry attempts
    function setupButtonHandlers() {
      const btnSignIn = document.getElementById('btnSignIn');
      const btnCreateAccount = document.getElementById('btnCreateAccount');
      const btnRegister = document.getElementById('btnRegister');
      const btnBackToLogin = document.getElementById('btnBackToLogin');
      
      let setupComplete = false;
      
      if (btnSignIn) {
        btnSignIn.onclick = (e) => {
          if (e) e.preventDefault();
          handleLogin();
        };
        setupComplete = true;
      }
      
      if (btnCreateAccount) {
        btnCreateAccount.onclick = (e) => {
          if (e) e.preventDefault();
          showRegister();
        };
        setupComplete = true;
      }
      
      if (btnRegister) {
        btnRegister.onclick = (e) => {
          if (e) e.preventDefault();
          handleRegister();
        };
        setupComplete = true;
      }
      
      if (btnBackToLogin) {
        btnBackToLogin.onclick = (e) => {
          if (e) e.preventDefault();
          showLogin();
        };
        setupComplete = true;
      }
      
      return setupComplete;
    }
    
    // Try to setup handlers immediately
    if (!setupButtonHandlers()) {
      // If not found, retry after 50ms
      setTimeout(setupButtonHandlers, 50);
      // And again after 150ms
      setTimeout(setupButtonHandlers, 150);
    }
