          };
          playerList.appendChild(userBtn);
        });
        
        content.appendChild(playerList);
        const cancelBtn = document.createElement('button');
        cancelBtn.className = 'btn btn-secondary';
        cancelBtn.type = 'button';
        cancelBtn.textContent = 'Cancel';
        cancelBtn.onclick = () => modal.remove();
        content.appendChild(cancelBtn);
        
        modal.appendChild(content);
        document.body.appendChild(modal);
      } else if (type === 'all') {
        const confirmDiv = document.createElement('div');
        confirmDiv.style.background = '#e8f5e9';
        confirmDiv.style.padding = '15px';
        confirmDiv.style.borderRadius = '6px';
        confirmDiv.style.border = '2px solid #27ae60';
        confirmDiv.style.marginBottom = '15px';
        
        const targetCount = allUsers.length - 1;
        confirmDiv.innerHTML = `
          <strong>⚠️ Send ${seedCount} legendary seeds to ALL ${targetCount} players?</strong><br>
          <small>This will give ${seedCount} legendary seeds to every player on the server.</small>
        `;
        
        const confirmBtn = document.createElement('button');
        confirmBtn.className = 'btn';
        confirmBtn.style.background = '#27ae60';
        confirmBtn.type = 'button';
        confirmBtn.textContent = '✅ Send to Everyone';
        confirmBtn.style.marginRight = '10px';
        confirmBtn.onclick = async () => {
          confirmBtn.disabled = true;
          confirmBtn.textContent = 'Sending...';
          
          let sent = 0;
          for (const user of allUsers) {
            if (user.id !== currentUser.id) {
              user.legendaryPetSeeds = (user.legendaryPetSeeds || 0) + seedCount;
              const updateResult = await window.dataSdk.update(user);
              if (updateResult.isOk) {
                sent++;
              }
              await new Promise(resolve => setTimeout(resolve, 50));
            }
          }
          
          showNotification(`✅ Sent ${seedCount} seeds to ${sent} players! 🌱`);
          confirmBtn.textContent = '✅ Complete!';
          setTimeout(() => {
            confirmDiv.remove();
            resultDiv.innerHTML = `<div class="message success-message">✅ Distributed ${seedCount * sent} legendary seeds total!</div>`;
          }, 500);
        };
        confirmDiv.appendChild(confirmBtn);
        
        const cancelBtn = document.createElement('button');
        cancelBtn.className = 'btn-small btn-secondary';
        cancelBtn.type = 'button';
        cancelBtn.textContent = 'Cancel';
        cancelBtn.onclick = () => {
          confirmDiv.remove();
        };
        confirmDiv.appendChild(cancelBtn);
        
        resultDiv.appendChild(confirmDiv);
      }
    }
    
