    async function sendPetToUser(recipient, petIndex) {
      const pets = currentUser.ownedPets.split(',');
      const rarities = currentUser.petRarities.split(',');
      const levels = currentUser.petLevels.split(',');
      const names = currentUser.petNames.split(',');
      const hps = currentUser.petCurrentHP.split(',');
      
      const petToSend = pets[petIndex];
      const rarityToSend = rarities[petIndex];
      const levelToSend = levels[petIndex];
      const nameToSend = names[petIndex];
      const hpToSend = hps[petIndex];
      
      pets.splice(petIndex, 1);
      rarities.splice(petIndex, 1);
      levels.splice(petIndex, 1);
      names.splice(petIndex, 1);
      hps.splice(petIndex, 1);
      
      currentUser.ownedPets = pets.join(',');
      currentUser.petRarities = rarities.join(',');
      currentUser.petLevels = levels.join(',');
      currentUser.petNames = names.join(',');
      currentUser.petCurrentHP = hps.join(',');
      
      const recPets = recipient.ownedPets ? recipient.ownedPets.split(',').filter(p => p) : [];
      const recRarities = recipient.petRarities ? recipient.petRarities.split(',').filter(r => r) : [];
      const recLevels = recipient.petLevels ? recipient.petLevels.split(',').filter(l => l) : [];
      const recNames = recipient.petNames ? recipient.petNames.split(',').filter(n => n) : [];
      const recHPs = recipient.petCurrentHP ? recipient.petCurrentHP.split(',').filter(h => h) : [];
      
      recPets.push(petToSend);
      recRarities.push(rarityToSend);
      recLevels.push(levelToSend);
      recNames.push(nameToSend);
      recHPs.push(hpToSend);
      
      recipient.ownedPets = recPets.join(',');
      recipient.petRarities = recRarities.join(',');
      recipient.petLevels = recLevels.join(',');
      recipient.petNames = recNames.join(',');
      recipient.petCurrentHP = recHPs.join(',');
      
      await window.dataSdk.update(currentUser);
      await window.dataSdk.update(recipient);
      
      showNotification(`Sent ${nameToSend} to ${recipient.username}! 🐾`);
      updateUI();
    }

